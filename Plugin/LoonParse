#!name = 订阅解析器
#!desc = 支持对订阅节点进行本地解析与管理 编辑节点使用正则表达式语法匹配\n\n• 排除节点：匹配到的节点将被删除\n• 保留节点：仅保留匹配到的节点，其余全部删除\n• 删除名称：删除节点名称中匹配到的内容\n• 重新命名：格式为 旧名:新名 多个重命使用,分隔\n• 节点排序：格式为 香港>台湾 会按写入的顺序排 \n\n可启用伪装 User-Agent，请求订阅时模拟 Shadowrocket 小火箭客户端进行访问，兼容部分针对 Loon 存在限制
#!icon = https://png.pngtree.com/png-clipart/20250428/original/pngtree-research-science-laboratory-vector-png-image_20866920.png
#!type = parser
#!loon_version = 3.5.0

[Argument]
keep = input,"",tag=保留节点
drop = input,"",tag=排除节点
wipe = input,"",tag=删除名称
name = input,"",tag=重新命名
sort = input,"",tag=节点排序
emoji = switch,false,tag=移除国旗
ua = switch,false,tag=启用伪装UA

[Script]
generic script-path=https://github.com/JinKeel/Loon/raw/refs/heads/main/JS/Parse.js, tag=资源解析器, timeout=10, argument=[{keep},{drop},{wipe},{name},{sort},{emoji},{ua}]
