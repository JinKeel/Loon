#!name = 资源解析器
#!desc = 对订阅节点进行本地解析处理 在拉取订阅时对节点进行筛选与整理\n\n通过正则,过滤节点,保留节点,删除节点名\n\n节点重命名格式列如 旧名+新名 多个用,连接 \n\n启用UA兼容使用Shadowrocket以访问部分不兼容Loon的订阅
#!icon = https://raw.githubusercontent.com/JinKeel/Loon/refs/heads/main/icon/Loon.png
#!loon_version = 3.5.0(970)
#!type = parser

[Argument]
exclude = input,"",tag=正则过滤
include = input,"",tag=正则保留
del = input,"",tag=正则删除
rename = input,"",tag=正则重名
ua = switch,false,tag=启用伪装UA

[Script]
generic script-path=https://github.com/JinKeel/Loon/raw/refs/heads/main/JS/Parse.js, tag=资源解析器, timeout=10, argument=[{exclude},{include},{del},{rename},{ua}]
