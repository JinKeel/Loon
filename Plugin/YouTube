#!name = YouTube视频
#!desc = 屏蔽推荐广告视频播放广告
#!icon = https://upload.wikimedia.org/wikipedia/commons/thumb/f/fc/YouTube_play_button_square_%282013-2017%29.svg/500px-YouTube_play_button_square_%282013-2017%29.svg.png

[Argument]
blockUpload=switch, true, tag=关闭上传入口
blockShorts=switch, true, tag=关闭短视频
debug=switch, false, tag=启用日志输出

[Rewrite]
^https:\/\/[^\/]+\.googlevideo\.com\/initplayback.+&oad mock-response-body data-type=text data="" status-code=200

[Script]
http-response ^https:\/\/[^\/]+\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch)) script-path=https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js, requires-body=true, binary-body-mode=true, argument=[{blockUpload},{blockShorts},{debug}], tag=广告处理

[MitM]
hostname = *.googlevideo.com,youtubei.googleapis.com
